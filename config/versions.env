# config/versions.env — central version + checksum manifest for pocket-homeserver.
#
# This is the SINGLE place to see and change the pinned version of every component
# the installer fetches or builds. It is sourced by scripts/lib/common.sh AFTER
# .env (so an explicit .env value still wins) and BEFORE any install step runs, so
# every scripts/steps/* and scripts/apps/* script reads its pin from here.
#
# Precedence (each entry uses the ${VAR:-default} form):
#     .env value                 your override (highest)
#       > this manifest          the maintained, in-effect pin
#         > the step's inline    last-resort fallback if this file is ever absent
#
# DO NOT hand-bump in a hurry. Use:
#     scripts/ops/update.sh <component> --to <ver> --sha256 <hash> --confirm
# which snapshots first, verifies the download fail-closed, re-runs the step,
# health-checks the service, and rolls back on a crash loop. See docs/UPDATING.md.
#
# Integrity model:
#   * sha256-pinned binaries/archives — fetch_verified() refuses a mismatch (fail-closed).
#   * source/tag builds (no sha)       — integrity = the immutable git tag/ref over HTTPS.
#   * apt packages (Caddy)             — managed by the Debian/Cloudsmith apt repo, not pinned here.
#   * Python (MCP)                     — pinned with == in scripts/mcp/requirements.txt.

# ── Core edge & homeserver ───────────────────────────────────────────────────
# cloudflared (Cloudflare Tunnel) — sha256-pinned binary.
CF_VER="${CF_VER:-2026.3.0}"
CF_SHA256="${CF_SHA256:-0755ba4cbab59980e6148367fcf53a8f3ec85a97deefd63c2420cf7850769bee}"

# continuwuity (Matrix homeserver) — sha256-pinned binary.
# DB-SCHEMA TIER: a downgrade after a schema bump is NOT auto-reversible. update.sh
# snapshots the DB first and treats a rollback here as snapshot-restore, not a
# binary swap — confirm before changing. See docs/UPDATING.md + docs/RESILIENCE.md.
CW_VER="${CW_VER:-0.5.9}"
CW_SHA256="${CW_SHA256:-d325133456241bf64e4dec5dc905fc0513b1e3fb7eaaa927f51726b801a9d3d2}"

# Element Web (Matrix client) — sha256-pinned archive.
EL_VER="${EL_VER:-v1.12.15}"
EL_SHA256="${EL_SHA256:-3a729326fe295b3631ba17bda0775db30f41a6bb0ba12a4aff4d5f488d5e91e3}"

# ── Optional apps — sha256-pinned release artifacts ──────────────────────────
MEMOS_VER="${MEMOS_VER:-0.29.0}"
MEMOS_SHA256="${MEMOS_SHA256:-ed8379f95250ecff330332d403182120e7498032006e1e73d91cf0f1831087be}"

VIKUNJA_VERSION="${VIKUNJA_VERSION:-2.3.0}"
VIKUNJA_SHA256="${VIKUNJA_SHA256:-62863bddd7d29e7437e9ea019010540c53cd71a205354952b5cd47bec28863cb}"

FRESHRSS_VERSION="${FRESHRSS_VERSION:-1.29.1}"
FRESHRSS_SHA256="${FRESHRSS_SHA256:-b956aa4cd1f4d65eaad626a2648fecfdcbb7cdebf9253f3f4064965aefcd28cc}"

# it-tools — sha256-pinned release zip, plus the figlet build it bundles.
ITTOOLS_VERSION="${ITTOOLS_VERSION:-2024.10.22-7ca5933}"
ITTOOLS_ZIP_SHA256="${ITTOOLS_ZIP_SHA256:-eef276d675db6053bdc65cd8482a566785561c70eed5035a0e05b0e627b0989d}"
FIGLET_VER="${FIGLET_VER:-1.6.0}"
FIGLET_SHA256="${FIGLET_SHA256:-0d4da17fef5432b7ffd0ca00980b89dca38e694fadb8d919977e6371f034d7d9}"

# ── Files & sync (optional) — sha256-pinned ──────────────────────────────────
# dufs (web file server + WebDAV). Upstream publishes NO checksum file, so this
# hash was computed from the canonical GitHub release asset
# (dufs-v${DUFS_VER}-aarch64-unknown-linux-musl.tar.gz). Re-hash by hand on bump.
DUFS_VER="${DUFS_VER:-0.46.0}"
DUFS_SHA256="${DUFS_SHA256:-1472123ae3aa07e49404d16b20305c2dec90c59883ebda9308717f7205e6511b}"

# filebrowser (classic v2 web file manager) — hash from the published
# filebrowser_${FILEBROWSER_VER}_checksums.txt (linux-arm64-filebrowser.tar.gz).
FILEBROWSER_VER="${FILEBROWSER_VER:-2.63.15}"
FILEBROWSER_SHA256="${FILEBROWSER_SHA256:-74dd4e2403235987e4dba26b6e34a6f2c56e9fc98e13d9205c079f9e1c8c42f5}"

# syncthing (P2P file sync) — hash from the PGP-clearsigned sha256sum.txt.asc
# (syncthing-linux-arm64-v${SYNCTHING_VER}.tar.gz).
SYNCTHING_VER="${SYNCTHING_VER:-2.1.1}"
SYNCTHING_SHA256="${SYNCTHING_SHA256:-2c831e27c73a5c9217bdbbfcdb695d41b027f9d8bf8303f55590881e7b907f7f}"

# ── Productivity & security (optional) — pinned ──────────────────────────────
# Wallabag (read-later). The official bundled tarball ships vendor/ pre-installed
# (no composer on the phone). Upstream publishes only an MD5 (on the release blog),
# so this sha256 was COMPUTED by hashing the GitHub release asset — the fail-closed
# integrity anchor. Re-hash on bump: sha256sum wallabag-<ver>.tar.gz.
WALLABAG_VERSION="${WALLABAG_VERSION:-2.6.14}"
WALLABAG_SHA256="${WALLABAG_SHA256:-0049345aec597dace8e2be2c85c2b8e7744217fe15fd5303bcab3811719eff0d}"

# Trilium Notes (TriliumNext fork) — first-party arm64 SERVER tarball (bundled Node
# + prebuilt better-sqlite3; no node-gyp). Hash = the official release asset digest.
TRILIUM_VERSION="${TRILIUM_VERSION:-0.103.0}"
TRILIUM_SHA256="${TRILIUM_SHA256:-4639c70af54847f13167d942f2e906af633c5f51e78f965e54c9901d4bd94ca6}"

# Radicale (CalDAV/CardDAV/tasks) — pure-Python wheel from PyPI (per-file sha256
# on PyPI; pip verifies). Pinned by version; bcrypt installs from a prebuilt
# aarch64 wheel (forced --only-binary, fail-closed — never a Rust compile).
RADICALE_VERSION="${RADICALE_VERSION:-3.7.5}"

# Vaultwarden (Bitwarden-compatible) — upstream ships NO standalone binary, only
# Docker images. We daemonless-extract the musl-static binary + version-locked
# web-vault from the OFFICIAL image, pinned by the arm64 IMAGE MANIFEST DIGEST
# (content-addressed; each layer blob is digest-verified). VAULTWARDEN_BIN_SHA256
# is the sha256 of the EXTRACTED /vaultwarden binary (self-derived — see
# scripts/apps/vaultwarden.sh + docs/VAULT.md). On bump, re-derive ALL FOUR.
VAULTWARDEN_TAG="${VAULTWARDEN_TAG:-1.36.0-alpine}"
VAULTWARDEN_MANIFEST_ARM64="${VAULTWARDEN_MANIFEST_ARM64:-sha256:a925c18b92e794fb199026003e9c22e4fa0e5d44cf53abc98dc15eb91e1ba2a4}"
VAULTWARDEN_BIN_SHA256="${VAULTWARDEN_BIN_SHA256:-dfdf0b37bc6289cbd0fc082aa79451173b12256d396fb953137a3b857755bcbe}"
VAULTWARDEN_WEBVAULT_VERSION="${VAULTWARDEN_WEBVAULT_VERSION:-2026.4.1}"

# ── Email / webmail — sha256-pinned ──────────────────────────────────────────
SNAPPYMAIL_VERSION="${SNAPPYMAIL_VERSION:-2.38.2}"
SNAPPYMAIL_SHA256="${SNAPPYMAIL_SHA256:-71f1d8a9065cc9cf7ddd064f5c47cc7b255cb70e6a56713647fc73d4b79e33ec}"

# maddy (mail server) — SHA256 is a PLACEHOLDER: set the real hash of the arm64
# archive you download before enabling email. fetch_verified fails closed until
# you do, so email simply will not install with the placeholder in place.
MADDY_VERSION="${MADDY_VERSION:-0.9.5}"
MADDY_SHA256="${MADDY_SHA256:-PLACEHOLDER_SET_REAL_SHA256_SEE_TODO_human_pin}"

# ── Build-from-source — integrity = the immutable git tag/ref over HTTPS ──────
GATUS_VER="${GATUS_VER:-5.36.0}"               # built from source with the Go toolchain below
PINGVIN_TAG="${PINGVIN_TAG:-v1.19.0}"
LINKDING_VERSION="${LINKDING_VERSION:-1.45.0}"  # LINKDING_TAG is derived as v${LINKDING_VERSION}
# Go toolchain used to build Gatus — sha256-pinned.
GO_VER="${GO_VER:-1.26.3}"
GO_SHA256="${GO_SHA256:-9d89a3ea57d141c2b22d70083f2c8459ba3890f2d9e818e7e933b75614936565}"

# MOVING refs — these track a branch HEAD and are NOT reproducible pins. Pin each
# to a specific commit for a reproducible build; left at the upstream default here.
SEARXNG_REF="${SEARXNG_REF:-master}"
STICKERPICKER_REF="${STICKERPICKER_REF:-master}"
