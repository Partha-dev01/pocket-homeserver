# conduwuit / continuwuity config template for pocket-homeserver.
# Rendered to config/rendered/conduwuit.toml by scripts/render-config.sh, which
# substitutes ${MATRIX_SERVER_NAME}.
#
# Rate-limiting key names vary between server versions; cross-check against your
# installed build's example config before relying on them.

[global]
server_name        = "${MATRIX_SERVER_NAME}"
database_backend   = "rocksdb"
database_path      = "/var/lib/conduwuit/db"
address            = "127.0.0.1"
port               = 8448
max_request_size   = 52428800            # 50 MB

# ── Crash / unclean-shutdown durability (OPTIONAL — TEST on your build first) ──
# A phone homeserver is reboot- and low-memory-killer-prone; an unclean kill
# mid-write can leave RocksDB unable to open (a MANIFEST referencing SSTs that
# were never fsync'd) → conduwuit crash-loops. pocket-homeserver already (a) backs
# off + raises a DEGRADED flag instead of hammering a broken DB, (b) takes DAILY
# DB backups so loss is bounded, and (c) ships scripts/ops/restore.sh — see
# docs/RESILIENCE.md. You can ADDITIONALLY ask RocksDB to self-recover to the last
# consistent point on open. Option names/semantics VARY by continuwuity build, and
# a key your build rejects fails CLOSED at startup — so these are left OFF here;
# cross-check your version's example config, then uncomment and confirm the server
# still starts before relying on them:
#
#   # Recover to the last consistent point rather than refusing to open after a
#   # torn write (drops only the un-fsync'd tail). 2 = PointInTime on most builds.
#   rocksdb_recovery_mode = 2
#
#   # Leave rocksdb_repair OFF by default — repair can be lossy. Only run a repair
#   # deliberately on an already-broken DB (or just restore.sh the last backup).
#   # rocksdb_repair = false

# Registration is closed; create accounts with single-use invite tokens minted
# by the admin. Set a strong token out-of-band — never commit it here.
allow_registration = false
# registration_token = "<strong-random-value>"

# Federation OFF — the single most important hardening line for a private server.
allow_federation        = false
allow_outgoing_presence = false
allow_incoming_presence = false

# Keep the room directory private (no anonymous enumeration).
allow_public_room_directory_over_federation = false
allow_public_room_directory_without_auth    = false

[global.media]
# Media path is bind-mounted onto the large volume (${DATA_DIR}) at runtime.
path             = "/var/lib/conduwuit/media"
max_request_size = 52428800              # 50 MB per upload
