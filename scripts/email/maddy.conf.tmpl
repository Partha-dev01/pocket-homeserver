## maddy.conf — pocket-homeserver email engine (rendered by steps/85-install-email.sh).
##
## Maddy here is a LOCAL store + loopback IMAP + a submission->smarthost relay.
## It is DELIBERATELY NOT a public MX: there is no :25 listener and nothing binds a
## public address. Inbound mail ENTERS over loopback only — the native drain
## (mail-drain.py) pulls raw mail from R2 and injects it into the :__INJECT_PORT__
## endpoint below. Outbound goes through the Resend smarthost. See docs/EMAIL.md.
##
## The installer renders this template by substituting the __PLACEHOLDER__ tokens
## (hostname/domain/ports) from .env; relay credentials are NEVER written here —
## they come from the environment ({env:...}), exported by the in-userland launcher
## from a 0600 secrets file so they never reach argv / ps.

state_dir /opt/maddy/state
runtime_dir /opt/maddy/run

$(hostname) = __MAIL_HOSTNAME__
$(primary_domain) = __MAIL_DOMAIN__
$(local_domains) = $(primary_domain)

# Every listener below is loopback-only; public TLS is terminated upstream
# (Caddy / the Cloudflare Tunnel) for any webmail front end. Maddy needs no public
# cert on loopback -> plaintext.
tls off

# Global EHLO/greeting hostname, inherited by every endpoint. (The $(hostname)
# above is only a macro/variable; THIS line is the actual required maddy directive.)
hostname $(hostname)

# ---- storage: imapsql (SQLite). WAL + busy_timeout for concurrent IMAP/inject. ----
storage.imapsql local_mailboxes {
    driver sqlite3
    dsn /opt/maddy/state/imapsql.db?_journal_mode=WAL&_busy_timeout=5000
}

# ---- auth: local password table (SQLite). Accounts created by the installer. ----
auth.pass_table local_authdb {
    table sql_table {
        driver sqlite3
        dsn /opt/maddy/state/credentials.db?_busy_timeout=5000
        table_name passwords
    }
}

# ---- IMAP for a webmail client (loopback) ----
imap tcp://127.0.0.1:__IMAP_PORT__ {
    tls off
    auth &local_authdb
    storage &local_mailboxes
}

# ---- INJECT endpoint (loopback, AUTH REQUIRED) ----
# mail-drain.py delivers fetched INBOUND mail here. A `submission` endpoint is used
# because it REQUIRES auth -> closes the Android shared-loopback hole (any app with
# the INTERNET permission can reach a localhost port). We do NOT load
# check.authorize_sender, so an authenticated client may use ANY MAIL FROM (inbound
# mail carries the original external sender). All recipients deliver locally;
# submission only inserts Date/Message-ID when MISSING (real inbound mail already
# has them -> byte-preserved bar one added Received header).
submission tcp://127.0.0.1:__INJECT_PORT__ {
    tls off
    insecure_auth yes
    auth &local_authdb
    source $(local_domains) {
        default_destination { deliver_to &local_mailboxes }
    }
    default_source {
        default_destination { deliver_to &local_mailboxes }
    }
}

# ---- SUBMISSION for OUTBOUND mail (loopback) -> smarthost ----
submission tcp://127.0.0.1:__SUBMISSION_PORT__ {
    tls off
    insecure_auth yes
    auth &local_authdb
    source $(local_domains) {
        destination postmaster $(local_domains) { deliver_to &local_mailboxes }
        destination $(local_domains)            { deliver_to &local_mailboxes }
        default_destination                     { deliver_to &outbound_smarthost }
    }
    default_source {
        reject 501 5.1.8 "Non-local sender not allowed for submission"
    }
}

# ---- Outbound smarthost: Resend :587 STARTTLS. ----
# Resend signs DKIM for the sending domain (so DMARC aligns); Maddy does no
# self-signing here (no modify.dkim). The SMTP user is the literal "resend"; the
# password is the Resend API key, read from the environment as {env:RESEND_API_KEY}
# (exported by the launcher from a 0600 secrets file — never hard-coded here).
#
# To use a different SMTP relay instead of Resend, replace the targets line + the
# auth line, e.g. a generic relay:
#   targets tcp://smtp.your-relay.example:587
#   auth plain {env:SMARTHOST_USER} {env:SMARTHOST_PASS}
target.smtp outbound_smarthost {
    targets tcp://smtp.resend.com:587
    starttls yes
    auth plain resend {env:RESEND_API_KEY}
}
