# pocket-homeserver — configuration
#
# The easy path: run `./pocket.sh` from the repo root and choose "Configure" (or
# run `./setup.sh` directly) for a guided wizard that asks a handful of questions
# and writes a complete `.env` for you.
#
# Prefer to do it by hand? Copy this file and edit it:
#
#     cp .env.example .env
#
# Either way, the install scripts read these values. `.env` is gitignored — your
# real values are never committed.
# Nothing in THIS file should be a real secret; keep secrets only in your `.env`.
#
# Values are expanded by bash (the scripts `source` this file), so `${DOMAIN}`
# and `$HOME` references below resolve as expected.
#
# Component VERSIONS + checksums are NOT set here — they're pinned centrally in
# config/versions.env. Bump them with `scripts/ops/update.sh` (it snapshots and
# rolls back on failure); see docs/UPDATING.md. You can still override any pin here.

# ─── Core ─────────────────────────────────────────────────────────────────
# Your apex domain (its DNS must be managed by Cloudflare).
DOMAIN=example.com

# Timezone (IANA name) used by services and scheduled jobs.
TZ=Etc/UTC

# Matrix homeserver identity. User IDs look like @alice:${MATRIX_SERVER_NAME}.
MATRIX_SERVER_NAME=${DOMAIN}

# ─── Storage (Android / Termux) ─────────────────────────────────────────────
# Absolute path to the large data store. On a phone this is usually the SD card,
# e.g. /storage/XXXX-XXXX/pocket-homeserver  (XXXX-XXXX = your card's volume id).
DATA_DIR=/storage/XXXX-XXXX/pocket-homeserver

# proot Debian rootfs location (defaults to inside Termux $HOME).
ROOTFS_DIR=$HOME/debian

# ─── Cloudflare Tunnel (ingress) ────────────────────────────────────────────
# Create a tunnel in the Cloudflare Zero Trust dashboard and paste its token.
# KEEP THIS SECRET — set it only in your local .env, never here.
CF_TUNNEL_TOKEN=

# Local address Caddy listens on; the tunnel forwards public traffic here.
CADDY_BIND=127.0.0.1
CADDY_PORT=8443

# ─── Matrix homeserver (continuwuity / conduwuit) ───────────────────────────
# Single-server defaults: federation and registration are OFF (simplest/safest)
# and are baked into the homeserver config — there are no .env toggles for them.
# To create your first (admin) account, AFTER the stack is up run
# scripts/ops/rotate-registration-token.sh — it mints a token and opens
# token-gated signup; then register at chat.${DOMAIN}. See docs/SETUP.md step 8.

# ─── Web admin panel ─────────────────────────────────────────────────────────
# A phone-friendly control panel: health, stats, logs, service restarts, backups,
# and a guarded danger zone. On by default; set ENABLE_ADMIN=false to skip it.
# Runs Termux-native on loopback and is fronted by Caddy at ADMIN_HOST. Protect
# that hostname with Cloudflare Access in the dashboard. See docs/ADMIN.md.
ENABLE_ADMIN=true
ADMIN_HOST=admin.${DOMAIN}
ADMIN_USER=admin
ADMIN_PASSWORD=
# Loopback port the panel binds (Caddy fronts it; never exposed directly).
ADMINWEB_PORT=9000
# Brand shown in the panel header / PWA (defaults to your domain).
ADMIN_BRAND=${DOMAIN}
# Session idle timeout in minutes.
ADMIN_IDLE_MINUTES=30
# Advanced: set to 1 to mark the session cookie Secure (HTTPS-only), forbidding
# loopback/HTTP access. Leave 0 unless you front the panel with TLS end to end.
ADMINWEB_SECURE_COOKIE=0
# Optional: validate the Cloudflare Access JWT at the panel too (defense in depth).
# Leave CF_ACCESS_TEAM_DOMAIN empty to disable (the default). MODE: log | enforce.
CF_ACCESS_MODE=log
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ─── Reboot survival ─────────────────────────────────────────────────────────
# On by default. Installs a Termux:Boot launcher (auto-starts the whole stack on
# phone boot) and a JobScheduler watchdog (~15 min) that revives any service
# Android's low-memory killer takes down. Setup is fail-soft: it needs the
# Termux:Boot and Termux:API addon apps (from F-Droid) to actually fire, but the
# installer never errors if they're absent — it just tells you what to install.
ENABLE_BOOT=true

# ─── Optional Matrix-SSO auth gateway (advanced) ─────────────────────────────
# Off by default. When true, a small loopback service lets your users sign into
# the apps with their Matrix username + password (single sign-on across all your
# apps) instead of a separate per-app account. The DEFAULT app protection is
# Cloudflare Access + each app's own login; this is an opt-in advanced add-on.
# See docs/MATRIX_AUTH_GW.md and docs/APP_AUTH.md.
ENABLE_AUTH_GATEWAY=false
# Loopback port the gateway binds (reached via Caddy; never exposed directly).
AUTHGW_PORT=9095
# Localparts (or full @user:server MXIDs) granted admin in the OIDC role claim /
# the Remote-Admin header. Comma-separated; empty = nobody is auto-admin.
AUTHGW_ADMINS=
# Session-cookie scope. Default ${DOMAIN} = ONE login across all *.${DOMAIN}
# apps. Set empty for host-only (each subdomain keeps its own login).
AUTHGW_COOKIE_DOMAIN=${DOMAIN}
# Session lifetime in seconds (default 30 days; 604800 = 7 days).
AUTHGW_TTL=2592000
# Login-page brand shown on the sign-in form. Keep it simple (no quotes).
AUTHGW_BRAND=${DOMAIN}

# ─── Operator admin bot (optional) ───────────────────────────────────────────
# Off by default. When true, a small Termux-native Matrix bot lets YOU (and only
# you — it obeys exactly one operator MXID) drive the stack from a private
# admin-ops room: !status, !users, !invite-token, !private-list, !restart-stack
# (confirm-gated), etc. No inbound listener. The bot's token + room + your MXID
# live in a 0600 ${DATA_DIR}/secrets/adminbot.env (seeded by the install step),
# never in .env. Also gates the rotate-adminbot-token.sh / rotate-all.sh rotators.
# See docs/ADMINBOT.md.
ENABLE_ADMINBOT=false

# ─── Matrix bootstrap (optional, idempotent; off by default) ───────────────────
# When true, the installer runs scripts/steps/79-install-bootstrap.sh AFTER the
# stack is up to seed: an admin account, a hub Space + a few rooms, and an
# admin-only announcements room. Every helper is idempotent (re-running is safe).
# PREREQ: registration must be OPEN with a token — run
# scripts/ops/rotate-registration-token.sh first (the bootstrap is fail-soft and
# just warns if it isn't). See docs/BOOTSTRAP.md.
ENABLE_BOOTSTRAP=false
# Localpart of the Matrix admin account (MXID = @<this>:${MATRIX_SERVER_NAME}).
ADMIN_MATRIX_USER=admin
# Also generate + upload avatars for the admin/Space/announcements (needs Pillow:
# pip install Pillow). Off by default.
BOOTSTRAP_AVATARS=false
# Invite tokens minted by scripts/bootstrap/mint-invite-token.sh expire after N days.
INVITE_TOKEN_DAYS=7
# Structure template (all optional; neutral defaults shown — edit to taste).
MATRIX_SPACE_ALIAS=hub
MATRIX_SPACE_NAME="Community Hub"
MATRIX_SPACE_TOPIC="The landing space for community chat."
MATRIX_PRIVATE_ROOM_ALIAS=private
MATRIX_ANNOUNCE_ALIAS=announcements
# No secrets here — the admin password and registration token live in 0600 files
# under ${DATA_DIR}/secrets, never in .env.

# ─── Matrix user management in the admin panel (optional, off by default) ─────
# Adds a Users page to the admin panel: list / create / reset-password / suspend /
# unsuspend / deactivate, plus minting invite tokens. It works by sending commands
# to continuwuity's ADMIN ROOM (#admins:${MATRIX_SERVER_NAME}) as the admin account
# from ${DATA_DIR}/secrets/admin-credentials.env, and relaying the bot's reply.
# Generated passwords appear in that room's history — treat it as sensitive. The
# account must be a server admin (the first/bootstrap user is). See docs/USERS.md.
ENABLE_USER_ADMIN=false
# Command prefix continuwuity expects in the admin room. Default '!admin'. If your
# build wants bare commands there, set it empty: MATRIX_ADMIN_PREFIX=
# MATRIX_ADMIN_PREFIX=!admin
# Override the admin room if it isn't discoverable by alias:
# ADMIN_ROOM_ID=!yourAdminRoomId:${MATRIX_SERVER_NAME}

# ─── Optional apps ───────────────────────────────────────────────────────────
# Toggle each on/off. When enabled, each is served on its own subdomain of
# ${DOMAIN} (shown in the comment). Hostnames are finalized as scripts land.
# (The Matrix homeserver + the Element web client are CORE — always installed on
# chat.${DOMAIN} — so Element is not a toggle here.)
ENABLE_LINKDING=false   # bookmarks                 -> links.${DOMAIN}
ENABLE_PINGVIN=false    # file sharing              -> share.${DOMAIN}
ENABLE_FRESHRSS=false   # RSS reader                -> rss.${DOMAIN}
ENABLE_MEMOS=false      # notes                     -> notes.${DOMAIN}
ENABLE_VIKUNJA=false    # tasks                     -> tasks.${DOMAIN}
ENABLE_SEARXNG=false    # metasearch                -> search.${DOMAIN}
ENABLE_ITTOOLS=false    # developer tools           -> tools.${DOMAIN}
ENABLE_GATUS=false      # status page               -> status.${DOMAIN}

# ─── Backups ─────────────────────────────────────────────────────────────────
BACKUP_DIR=${DATA_DIR}/backups
BACKUP_KEEP_DB=3
BACKUP_KEEP_ROOTFS=4
# Optional age recipient (public key) for encrypted backups; empty = disabled.
BACKUP_AGE_RECIPIENT=
# To RESTORE an age-encrypted backup, scripts/ops/restore.sh needs the matching
# age PRIVATE key. Point this at that key FILE (an absolute path — and keep the
# file itself OFF the backup volume). It is a path, not a secret value. Leave
# empty unless you encrypt backups AND need to restore one.
BACKUP_AGE_IDENTITY=

# ─── Scheduled backups (optional daemon) ──────────────────────────────────────
# Off by default. When true, start-stack.sh supervises a small loop that wakes
# once a day and snapshots automatically: the Matrix DB on BACKUP_DB_CADENCE
# (below) and the full userland rootfs on the 1st of each month (UTC), then
# applies retention. Snapshots still go to ${BACKUP_DIR}. You can also keep
# running them on demand from `./pocket.sh` or the admin panel regardless.
ENABLE_BACKUP_DAEMON=false
# Hour of day (UTC, 0-23) the daemon wakes to run any due snapshot.
BACKUP_DAEMON_HOUR=4
# How often to snapshot the Matrix DB: daily | weekly | monthly. DEFAULT daily —
# a phone gets rebooted / low-memory-killed often, and an unclean kill can corrupt
# RocksDB; daily bounds data loss to <=1 day (the DB tar is small and the server
# pauses only for the snapshot, ~tens of seconds). See docs/RESILIENCE.md.
BACKUP_DB_CADENCE=daily
# Optional heartbeat URL (e.g. a healthchecks.io ping URL). If set, the daemon
# pings it after a successful DB backup, or "<url>/fail" if the backup failed,
# so an external monitor can alert you. Empty = no heartbeat (the default).
BACKUP_DAEMON_HC_URL=

# ─── Off-device encrypted backup (optional, off by default) ──────────────────
# Push the age-ENCRYPTED backup archives to an S3-compatible bucket (Cloudflare
# R2 / Backblaze B2 / AWS S3 / Wasabi / MinIO) so a lost or dead phone is not a
# lost backup. The backup daemon runs it after each retention pass; you can also
# run it on demand (./pocket.sh → backups, or scripts/ops/offsite-push.sh).
#
# REQUIRES BACKUP_AGE_RECIPIENT to be set (above) — it refuses to upload plaintext.
# The S3 credentials do NOT go here: create a 0600 file after setup —
#   ${DATA_DIR}/secrets/offsite.env  with
#     S3_ENDPOINT=https://<acct>.r2.cloudflarestorage.com   (HTTPS)
#     S3_BUCKET=...   S3_REGION=auto   S3_ACCESS_KEY_ID=...   S3_SECRET_ACCESS_KEY=...
#     S3_PREFIX=pocket          # optional folder/prefix in the bucket
# Remote retention mirrors BACKUP_KEEP_DB / BACKUP_KEEP_ROOTFS. Single-PUT only
# (objects must be < 5 GiB). See docs/BACKUPS.md "offsite".
ENABLE_OFFSITE_BACKUP=false

# ─── Service supervision / crash-loop alerting (optional) ─────────────────────
# Every long-running service is kept up by a supervisor that respawns it on exit.
# A service that keeps crashing fast is backed off exponentially and, after
# POCKET_CRASHLOOP_FAILS rapid failures, flagged DEGRADED (shown in the admin
# panel + status page) so a corrupt-DB crash loop can't silently hammer storage
# for hours. See docs/RESILIENCE.md. Defaults are sensible; tune only if needed:
#   POCKET_HEALTHY_SECS=60     # a child up >= this resets the backoff (healthy)
#   POCKET_RESPAWN_MIN=5       # first respawn delay (seconds)
#   POCKET_RESPAWN_MAX=300     # backoff cap (seconds) — stops fast hammering
#   POCKET_CRASHLOOP_FAILS=5   # rapid failures before DEGRADED + alert
# OPTIONAL one-shot alert command, run when ANY service enters DEGRADED. It runs
# via `sh -c` with $POCKET_ALERT_SERVICE / $POCKET_ALERT_RC / $POCKET_ALERT_FAILS
# in the environment (never on the command line). Empty = no alert (the default).
# Examples (pick one): a healthchecks.io fail ping, an ntfy push, a Matrix msg:
#   POCKET_ALERT_CMD='curl -fsS -m10 https://hc-ping.com/<uuid>/fail'
#   POCKET_ALERT_CMD='curl -fsS -m10 -d "pocket: $POCKET_ALERT_SERVICE crash-looping (rc=$POCKET_ALERT_RC)" ntfy.sh/<your-topic>'
POCKET_ALERT_CMD=

# ─── Observability / metrics sampler (optional, off by default) ──────────────
# A tiny supervised sampler that records cheap host-side numbers (CPU, memory,
# swap, load, disk, temperature, battery + the count of DEGRADED services) once a
# minute into a small capped JSONL "ring" file. The admin panel reads it to draw
# sparklines, a 24h health strip and a stats history (/metrics). NO inbound
# listener and NO network call. Cheap and recommended; off by default. The ring
# file lives on ext4 (~/.pocket/metrics), never the SD card. See docs/OBSERVABILITY.md.
ENABLE_METRICS=false
# Sample interval in seconds (min 5).
POCKET_METRICS_POLL_S=60
# Max samples kept in the ring (5760 ≈ 4 days at the 60s default).
POCKET_METRICS_RING=5760
# Poll the battery via termux-battery-status (needs the Termux:API addon). It
# self-disables if absent, so this is safe to leave on.
POCKET_METRICS_BATTERY=true

# ─── Honeypot (optional, alert-only by default) ──────────────────────────────
# A native watcher that tails the Caddy access log, flags high-confidence scanner
# probes (/.env, /.git, wp-login.php, phpMyAdmin, …) by the real client IP, and
# writes a JSONL ledger the admin panel's Security console reads. NO inbound
# listener and no Caddy change — zero new attack surface. Alert-only by default
# (it just writes the ledger). See docs/HONEYPOT.md.
ENABLE_HONEYPOT=false
# Optional decoy subdomains (comma-separated, e.g. nas.${DOMAIN},vpn.${DOMAIN}).
# Hits to these classify as decoy-host probes. Empty by default.
HONEYPOT_DECOY_HOSTS=
# Path to the Caddy JSON access log the watcher tails. Leave this unset: the
# watcher already defaults to <POCKET_LOG_DIR>/caddy-access.log (POCKET_LOG_DIR is
# derived from DATA_DIR at runtime). Uncomment + set an ABSOLUTE path only if you
# relocated Caddy's access log — do NOT use ${POCKET_LOG_DIR} here (it is not yet
# expanded when .env is sourced).
# HONEYPOT_CADDY_LOG=/absolute/path/to/caddy-access.log
#
# NOTE: Matrix alerts, Cloudflare edge blocking, and offline geo enrichment are
# NOT configured here. Matrix/CF are opt-in via 0600 files under
# ${DATA_DIR}/secrets (honeypot-alert.env for Matrix; cf-honeypot.env +
# honeypot.mode + honeypot-allow-blocking for blocking). Geo is opt-in by dropping
# the DB-IP lite datasets into scripts/honeypot/geo/. Secrets never go in .env.
# See docs/HONEYPOT.md.

# ─── Cloud-LLM Matrix chat bots (optional, off by default) ────────────────────
# Matrix bots that answer @-mentions via any OpenAI-compatible endpoint (Groq's
# free tier, OpenRouter, a local LLM). Native, loopback to the homeserver + one
# outbound HTTPS call per reply; NO inbound listener. Each bot is configured by a
# 0600 file ${DATA_DIR}/secrets/cloud-bot-<name>.env (token + API key ONLY there,
# never in .env). The install step seeds a template on the first enabled run. Run
# one OR more bots. See docs/CHATBOTS.md.
ENABLE_CLOUD_BOTS=false

# ─── On-phone LLM chat bot (exobot) — ADVANCED / bring-your-own-model ─────────
# Off by default. An on-device LLM Matrix bot: you supply your OWN llama.cpp
# 'llama-server' build (matching your phone's CPU) + a GGUF model; it lazy-loads
# /idle-unloads them to save RAM. Register a bot Matrix account and put its access
# token in ${DATA_DIR}/secrets/exobot.env (NOT here). See docs/CHATBOTS.md.
ENABLE_EXOBOT=false
# Bot account localpart → @<localpart>:${MATRIX_SERVER_NAME}.
EXOBOT_LOCALPART=exobot
# REQUIRED when enabled (BYO): your llama-server binary + GGUF model. With the
# default EXOBOT_PROOT_DISTRO=debian these are paths INSIDE the userland; set
# EXOBOT_PROOT_DISTRO= (empty) to use Termux-native host paths.
LLAMA_SERVER_BIN=
MODEL_PATH=
EXOBOT_PROOT_DISTRO=debian
# Loopback port the bot binds llama-server to.
LLAMA_SERVER_PORT=8081
# Keep the model resident (re-warm) vs lazy load-on-mention + idle-unload.
LLAMA_KEEP_WARM=true
EXOBOT_IDLE_TIMEOUT_S=600
# Comma-separated Matrix room IDs the bot may operate in (empty = none, fail-closed).
EXOBOT_ALLOWED_ROOMS=
# Optional engagement daemons (all default off). See docs/CHATBOTS.md.
INTERJECT_ENABLED=false
SEED_ENABLED=false
REVIVE_ENABLED=false
CROSSBOT_ENABLED=false
# Optional Gradio web UI in front of the same model (double-opt-in; off by default).
# It has NO login of its own — protect ai.${DOMAIN} with Cloudflare Access or the
# Matrix-SSO gateway (see docs/APP_AUTH.md).
EXOBOT_UI=false
EXOBOT_UI_PORT=9114
EXOBOT_WAKER_PORT=9116
EXOBOT_UI_TITLE="Self-hosted AI"
# Public hostname for the UI (defaults to ai.${DOMAIN}).
EXOBOT_UI_HOST_PUBLIC=ai.${DOMAIN}

# ─── Landing portal (optional, off by default) ────────────────────────────────
# A clean service directory served by Caddy at your apex domain (http://${DOMAIN}).
# The cards are generated from the ENABLE_* flags — one per enabled app. No bait or
# decoy content. Needs an apex Cloudflare Tunnel hostname (the install step prints
# the manual step). See docs/LANDING.md.
ENABLE_LANDING=false
# Brand shown in the portal title/header/footer (HTML-escaped at render). Defaults
# to ${DOMAIN}. Keep it plain text.
LANDING_BRAND=${DOMAIN}

# ─── Sticker picker (optional, off by default) ────────────────────────────────
# The third-party Maunium stickerpicker widget (AGPL — FETCHED at install, not
# vendored) + a native backend (uploads + Giphy proxy) + an optional DM-import
# bot. Served on its own vhost stickers.${DOMAIN}. See docs/STICKERS.md.
ENABLE_STICKERS=false
# Upstream picker to fetch (pin a commit sha for reproducibility if you like).
STICKERPICKER_REPO=https://github.com/maunium/stickerpicker.git
STICKERPICKER_REF=master
# Loopback port the native backend binds.
STICKER_BACKEND_PORT=8451
# Identity rollout: 'log' (allow + log unsigned widget URLs) → flip to 'enforce'
# (require a valid signature) once every user has a freshly-minted widget URL.
STICKER_IDENTITY_MODE=log
# REQUIRED when enabled: a Matrix access token for an account with media-upload
# rights (the backend uploads stickers on the verified caller's behalf). Create
# the account AFTER the homeserver is up, then paste its token here (this .env is
# 0600). The install step fail-louds if it is empty.
STICKER_SERVICE_TOKEN=
# Optional Giphy API key (enables the Giphy tab; empty just disables that tab).
GIPHY_API_KEY=
# Optional DM-import bot: a Matrix account users DM an image to add it to a pack.
STICKER_BOT_TOKEN=
STICKER_BOT_MXID=
# Optional: auto-register the picker as a personal widget on this admin account.
STICKER_ADMIN_TOKEN=
STICKER_ADMIN_MXID=

# ─── Privacy & media filters (optional) ──────────────────────────────────────
# Two small loopback proxies in front of the Matrix homeserver on a few specific
# routes. Both off by default; both run Termux-native, bind loopback only, and
# fail open. When you enable one, render-config.sh automatically routes the
# relevant Matrix paths through it (no hand-editing the Caddyfile). See
# docs/FILTERS.md.
#
# user-filter: hide chosen accounts from the member / user-directory search.
# Edit ${DATA_DIR}/secrets/private-users.txt (one MXID per line; re-read live).
ENABLE_USER_FILTER=false
# Loopback port the user-filter binds (Caddy routes search here). Default 8449.
USER_FILTER_PORT=8449
#
# media-filter: set a Content-Type (via magic bytes) on media the homeserver
# leaves untyped, so native mobile clients render thumbnails / link previews.
ENABLE_MEDIA_FILTER=false
# Loopback port the media-filter binds (Caddy routes media here). Default 8450.
MEDIA_FILTER_PORT=8450
#
# The homeserver loopback both filters forward to. Leave as the default unless
# you changed the conduwuit listener (it matches the core Caddyfile /_matrix route).
MATRIX_LOOPBACK=http://127.0.0.1:8448

# ─── Email + webmail (optional, off by default — ADVANCED) ────────────────────
# A full self-hosted mailbox: the Maddy engine (loopback IMAP/inject/submission,
# in the userland) + a native pull drain that fetches inbound mail from R2 + the
# SnappyMail webmail UI at webmail.${DOMAIN}. NOT a public MX — inbound arrives via
# Cloudflare Email Routing → a Worker → R2 → the drain; outbound goes through a
# smarthost (Resend). You provision these on YOUR OWN accounts (the install step
# and scripts/email/worker/README.md walk you through it). Secrets do NOT live in
# this file — you create 0600 files under ${DATA_DIR}/secrets after first run:
#   mail-r2.env    (R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET)
#   mail-relay.env (RESEND_API_KEY; the SMTP user is the literal "resend")
# The installer generates the inject + mailbox passwords itself. Matrix-SSO webmail
# additionally needs ENABLE_AUTH_GATEWAY=true. See docs/EMAIL.md + docs/WEBMAIL.md.
ENABLE_EMAIL=false
MAIL_DOMAIN=mail.${DOMAIN}           # the mail domain (Cloudflare Email Routing target)
MAIL_HOSTNAME=mx.mail.${DOMAIN}      # Maddy EHLO/greeting hostname
MAIL_IMAP_PORT=9143                  # loopback IMAP (the webmail reads this)
MAIL_INJECT_PORT=9125                # loopback inject (the drain delivers here, AUTH)
MAIL_SUBMISSION_PORT=9587            # loopback submission → smarthost (outbound)
MAIL_POLL=180                        # drain poll interval (seconds)
MAIL_ADMIN_LOCALPART=admin           # role/admin mail funnels to <this>@MAIL_DOMAIN
# Pinned Maddy release. You MUST set MADDY_SHA256 to the real checksum of the
# archive for your CPU arch — the step ships a placeholder so the download fails
# closed until you pin it (curl -fsSL "$MADDY_URL" | sha256sum). MADDY_ARCH is
# arm64 for a typical phone (amd64 on a PC test box).
# MADDY_VERSION=0.9.5
# MADDY_ARCH=arm64
# MADDY_SHA256=
# ─ Webmail (the UI half; shares ENABLE_EMAIL) ─
SNAPPYMAIL_FPM_PORT=9092             # loopback php-fpm pool for SnappyMail
ENABLE_WEBMAIL_ADMIN=false           # SnappyMail's native admin panel on webmail-admin.${DOMAIN} (behind CF Access)
# Advanced overrides (sensible defaults are derived from DOMAIN):
# SNAPPYMAIL_VERSION / SNAPPYMAIL_URL / SNAPPYMAIL_SHA256
# SNAPPYMAIL_OIDC_CLIENT_ID / SNAPPYMAIL_OIDC_AUTHORIZE_URL / _TOKEN_URL / _REDIRECT_URI
# SNAPPYMAIL_BRAND / SNAPPYMAIL_WELCOME_FROM

# ─── MCP server (optional, off by default — ADVANCED) ─────────────────────────
# An optional Model Context Protocol server so an MCP client (Claude Desktop,
# Claude Code, the claude.ai connector, …) can observe and operate the stack
# through a small, audited tool set. It is a thin protocol adapter: every tool
# wraps an already-vetted scripts/ops/* script or an existing admin probe — it
# adds NO new privileged operation. Built on the official `mcp` Python SDK in its
# own venv (~/pocket-mcp), Termux-native (it orchestrates the host). Off by
# default; read tools are on when enabled, mutating tools stay behind their own
# flags. See docs/MCP.md (how-to) + docs/MCP_SERVER_SPEC.md (design).
ENABLE_MCP=false
# Transport: stdio | http | both. 'stdio' (the recommended default) is launched
# on demand by the client over your existing SSH session — nothing is published
# and no credential is needed (the SSH/CF-Access channel IS the authentication).
# 'http' also serves a remote Streamable-HTTP transport on its own vhost (below),
# fail-closed behind Cloudflare Access + a bearer credential. 'both' does both.
MCP_TRANSPORT=stdio
# Subdomain label for the HTTP transport -> MCP_HTTP_HOST.${DOMAIN} (http/both
# modes only). Protect that hostname with Cloudflare Access in the dashboard.
MCP_HTTP_HOST=mcp
# Loopback port the HTTP transport binds (Caddy fronts it; never exposed directly).
MCP_HTTP_PORT=9120
# Mutating-tool tiers, both default OFF. MCP_ALLOW_OPERATE enables the operate
# tier (restart a service, run a backup, mint/rotate a registration token).
# MCP_ALLOW_DANGER enables the danger tier (soft/hard panic) — which ALSO requires
# a per-call typed confirmation, mirroring the admin panel danger zone. With both
# false the server is read-only.
MCP_ALLOW_OPERATE=false
MCP_ALLOW_DANGER=false
# Bearer credential for the HTTP transport. GENERATED at install into this 0600
# file (you do not set a value here) — it is a path, not a secret. Checked with a
# constant-time compare so a misconfigured Access policy alone cannot open the
# server. DATA_DIR is already set above, so this reference expands cleanly.
MCP_BEARER_TOKEN_FILE=${DATA_DIR}/secrets/mcp-bearer.cred
# Redact secret-shaped strings (tokens, keys, bearer values) from the output of
# the log-reading tool. Keep this true.
MCP_LOG_REDACT=true
# Comma-separated allowlist of log BASENAMES the log tool may read (a closed set —
# no arbitrary paths). The basenames below are the core stack logs under the
# runtime log dir; add an app's log basename here if you want the tool to read it.
MCP_ALLOWED_LOGS=caddy.log,caddy-access.log,cloudflared.log,matrix.log,adminweb.log,auth-gw.log,honeypot.log,backup-daemon.log
# Per-session call cap (requests/min) for the MCP server.
MCP_RATE_LIMIT=60/min
# (HTTP mode reuses the admin panel's CF_ACCESS_MODE / CF_ACCESS_TEAM_DOMAIN /
# CF_ACCESS_AUD above for in-process JWT validation — no new Cloudflare keys.)
